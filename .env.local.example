# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase Dashboard -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard -> Settings -> API -> Project API keys -> anon / public
# Safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Dashboard -> Settings -> API -> Project API keys -> service_role
# SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC_, never send to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret checked by /api/sync. Make up any long random string yourself,
# e.g. `openssl rand -hex 32`. The external cron job (cron-job.org) sends this
# in an Authorization header so only it can trigger a sync.
SYNC_SECRET=change-me-to-a-long-random-string
